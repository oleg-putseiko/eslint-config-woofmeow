{
  "name": "eslint-config-woofmeow",
  "version": "2.0.0-canary.2",
  "description": "ESLint configuration containing multiple presets for different projects",
  "license": "MIT",
  "author": "Oleg Putseiko <oleg.putseiko@gmail.com> (https://github.com/oleg-putseiko)",
  "keywords": [
    "eslint",
    "config",
    "preset",
    "prettier",
    "javascript",
    "typescript",
    "next",
    "react",
    "import",
    "fsd",
    "feature-sliced"
  ],
  "homepage": "https://github.com/oleg-putseiko/eslint-config-woofmeow",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oleg-putseiko/eslint-config-woofmeow.git"
  },
  "bugs": {
    "url": "https://github.com/oleg-putseiko/eslint-config-woofmeow/issues"
  },
  "type": "module",
  "main": "./dist/presets/index.js",
  "files": [
    "./dist/presets/**/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/presets/index.d.ts",
      "import": "./dist/presets/index.js",
      "require": "./dist/presets/index.js"
    },
    "./base": {
      "types": "./dist/presets/base.d.ts",
      "import": "./dist/presets/base.js",
      "require": "./dist/presets/base.js"
    },
    "./import/base": {
      "types": "./dist/presets/import/base.d.ts",
      "import": "./dist/presets/import/base.js",
      "require": "./dist/presets/import/base.js"
    },
    "./import/atomic": {
      "types": "./dist/presets/import/atomic.d.ts",
      "import": "./dist/presets/import/atomic.js",
      "require": "./dist/presets/import/atomic.js"
    },
    "./import/fsd": {
      "types": "./dist/presets/import/fsd.d.ts",
      "import": "./dist/presets/import/fsd.js",
      "require": "./dist/presets/import/fsd.js"
    },
    "./next": {
      "types": "./dist/presets/next.d.ts",
      "import": "./dist/presets/next.js",
      "require": "./dist/presets/next.js"
    },
    "./react": {
      "types": "./dist/presets/react.d.ts",
      "import": "./dist/presets/react.js",
      "require": "./dist/presets/react.js"
    },
    "./tailwindcss": {
      "types": "./dist/presets/tailwindcss.d.ts",
      "import": "./dist/presets/tailwindcss.js",
      "require": "./dist/presets/tailwindcss.js"
    },
    "./typescript": {
      "types": "./dist/presets/typescript.d.ts",
      "import": "./dist/presets/typescript.js",
      "require": "./dist/presets/typescript.js"
    }
  },
  "scripts": {
    "build": "npm run build:js && npm run build:ts",
    "build:js": "swc src -d dist --strip-leading-paths --ignore \"node_modules,**/*.test.ts,**/*.d.ts\"",
    "build:ts": "tsc && mkdir -p dist && find src -name \"*.d.ts\" -exec cp {} dist/ \\;",
    "lint": "eslint ./src -c ./eslint.config.mjs",
    "lint:fix": "yarn lint --fix && yarn format:fix",
    "lint:strict": "yarn lint --max-warnings=0 && yarn format",
    "format": "prettier -c .",
    "format:fix": "prettier -w .",
    "typecheck": "tsc --noEmit --incremental false",
    "setup:husky": "husky && chmod +x ./.husky/*",
    "deps:audit": "bash ./scripts/deps/audit.sh",
    "scripts:perms": "find ./scripts -type f -name \"*.sh\" -exec chmod +x {} +",
    "scripts:perms:track": "find ./scripts -type f -name \"*.sh\" -exec git update-index --chmod=+x {} +"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-fsd": "^3.0.0-canary.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "typescript-eslint": "^8.58.2"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0 <10.0.0",
    "typescript": ">=3.3.1 <6.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@swc/cli": "^0.5.2",
    "@swc/core": "^1.10.1",
    "@types/eslint-plugin-tailwindcss": "^3",
    "@types/eslint__eslintrc": "^3.3.0",
    "@types/eslint__js": "^9.14.0",
    "@types/node": "^24.12.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-sh": "^0.18.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": "^20.9.0 || >=21.1.0 <25.0.0"
  },
  "volta": {
    "node": "24.14.1",
    "yarn": "4.13.0"
  }
}
