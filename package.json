{
  "name": "eslint-config-woofmeow",
  "version": "2.0.0-canary.1",
  "description": "ESLint configuration containing multiple presets for different projects",
  "license": "MIT",
  "author": "Oleg Putseiko <oleg.putseiko@gmail.com> (https://github.com/oleg-putseiko)",
  "keywords": [
    "eslint",
    "eslintrc",
    "config",
    "preset",
    "prettier",
    "javascript",
    "typescript",
    "next",
    "react",
    "import",
    "fsd",
    "feature-sliced"
  ],
  "homepage": "https://github.com/oleg-putseiko/eslint-config-woofmeow",
  "repository": {
    "type": "git",
    "url": "https://github.com/oleg-putseiko/eslint-config-woofmeow"
  },
  "bugs": {
    "url": "https://github.com/oleg-putseiko/eslint-config-woofmeow/issues"
  },
  "type": "module",
  "main": "./dist/presets/index.js",
  "files": [
    "./dist/presets/**/*",
    "./dist/utils/**/*"
  ],
  "exports": {
    ".": "./dist/presets/index.js",
    "./flat": "./dist/presets/flat/index.js",
    "./base": "./dist/presets/flat/base.js",
    "./import": "./dist/presets/flat/import-base.js",
    "./import-atomic": "./dist/presets/flat/import-atomic.js",
    "./import-fsd": "./dist/presets/flat/import-fsd.js",
    "./next": "./dist/presets/flat/next.js",
    "./react": "./dist/presets/flat/react.js",
    "./typescript": "./dist/presets/flat/typescript.js"
  },
  "scripts": {
    "build": "yarn build:swc && yarn build:tsc",
    "build:swc": "swc src -d dist --strip-leading-paths",
    "build:tsc": "tsc",
    "lint": "eslint ./src/**/*.ts -c ./eslint.config.mjs",
    "lint:fix": "yarn lint --fix && yarn format:fix",
    "lint:strict": "yarn lint --max-warnings=0 && yarn format",
    "format": "prettier -c .",
    "format:fix": "prettier -w .",
    "typecheck": "tsc --noEmit --incremental false",
    "prepare": "husky install | chmod +x ./.husky/*"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.23.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint-config-next": "^15.2.4",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import-fsd": "^2.0.0",
    "eslint-plugin-react": "~7.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.28.0"
  },
  "peerDependencies": {
    "eslint": ">=3.0.0",
    "typescript": ">=3.3.1"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^18.2.0",
    "@commitlint/config-conventional": "^18.1.0",
    "@swc/cli": "^0.5.2",
    "@swc/core": "^1.10.1",
    "@types/eslint__eslintrc": "^2.1.2",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^22.10.1",
    "eslint": "^9.16.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.0.2",
    "prettier": "^3.0.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": "^20.9.0 || >=21.1.0",
    "yarn": ">=3.6.3"
  },
  "volta": {
    "node": "20.9.0",
    "yarn": "3.6.4"
  }
}
